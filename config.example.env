# GitHub Trending 页面地址。
TRENDING_URL=https://github.com/trending

# 抓取超时时间，单位为秒，默认建议 15。
FETCH_TIMEOUT=15

# 每次邮件中最多展示多少个热门项目。
TOP_N=20

# 本地快照保存目录，默认使用 data。
DATA_DIR=data

# SMTP 服务器地址，例如 QQ 邮箱、163 邮箱、Gmail 等。
SMTP_HOST=smtp.example.com

# SMTP 端口。若使用 SSL，一般填 465；若使用 STARTTLS，一般填 587。
SMTP_PORT=465

# SMTP 登录用户名，通常与发件邮箱一致。
SMTP_USERNAME=your_email@example.com

# SMTP 授权码。注意：很多邮箱这里不是登录密码，而是单独生成的授权码。
SMTP_PASSWORD=your_smtp_authorization_code

# 发件邮箱地址。
FROM_EMAIL=your_email@example.com

# 收件邮箱地址，可以填写自己的另一个邮箱。
TO_EMAIL=receiver@example.com

# 是否启用 STARTTLS。若端口为 465，程序会自动使用 SSL，此项通常填 false。
SMTP_USE_TLS=false
